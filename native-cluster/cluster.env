# cluster.env — shared configuration for the native RabbitMQ cluster.
# Sourced by every script in this directory (via lib.sh).
#
# The three nodes and their fixed IPs. Index 0 is the "seed" node that the
# others cluster onto. NODE_IPS[i] <-> NODE_HOSTS[i] are matched by position.
NODE_IPS=(10.194.178.81 10.194.179.88 10.194.179.89)
NODE_HOSTS=(rabbit1 rabbit2 rabbit3)

# Which node is the cluster seed (join target). 0 == first entry above.
SEED_INDEX=0

# Shared Erlang cookie — MUST be identical on every node and kept secret.
# Change this before using anywhere real. Generate one with:
#   openssl rand -hex 32
ERLANG_COOKIE="CHANGE_ME_TO_A_LONG_RANDOM_SECRET_5f3c9a1e"

# A cluster-wide administrator (guest is loopback-only, so you need this to
# reach the management UI / AMQP from other machines). Created by create-admin.sh.
RABBITMQ_ADMIN_USER="admin"
RABBITMQ_ADMIN_PASS="change-me-too"

# Ubuntu release codename used for the apt repositories (24.04 == noble).
UBUNTU_CODENAME="noble"

# Pin RabbitMQ to a specific version (prefix-matched against the apt repo, so
# "4.3.2" resolves to e.g. 4.3.2-1). Leave empty to install the latest available.
RABBITMQ_VERSION="4.3.2"

# --- Air-gapped install ---------------------------------------------------
# The nodes have NO internet access (only an internal apt mirror). Choose where
# 01-install.sh gets the packages:
#   offline-debs : install from a pre-staged local .deb bundle (no network at
#                  all beyond the internal mirror for base OS deps). Build the
#                  bundle on an internet-connected host with fetch-packages.sh.
#   apt-repo     : install straight from the internal apt mirror, which must
#                  already carry rabbitmq-server + erlang for ${UBUNTU_CODENAME}.
INSTALL_SOURCE="offline-debs"

# Where the .deb bundle lives on each node (used when INSTALL_SOURCE=offline-debs).
# Defaults to the packages/ dir next to these scripts.
OFFLINE_DEB_DIR=""
